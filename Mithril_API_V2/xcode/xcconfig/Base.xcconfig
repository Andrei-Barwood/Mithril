// Mithril API v2 base configuration (macOS Sequoia)
CLANG_CXX_LANGUAGE_STANDARD = gnu++20
GCC_C_LANGUAGE_STANDARD = gnu2x
SDKROOT = macosx
MACOSX_DEPLOYMENT_TARGET = 15.0
CLANG_ENABLE_MODULES = YES
ENABLE_TESTABILITY = YES
DEFINES_MODULE = YES
HEADER_SEARCH_PATHS = $(SRCROOT)/Mithril_API_V2/include
OTHER_CFLAGS = $(inherited) -DMITHRIL_USE_LIBSODIUM
OTHER_LDFLAGS = $(inherited) -lsodium
